<!--
  Project Sparring - Wazuh detection rules
  Deploy: append this <group> to /var/ossec/etc/rules/local_rules.xml on the
  Wazuh manager, then restart the manager (docker restart <manager-container>).

  These tag auditd events (generated by ../auditd/sparring.rules) with ATT&CK
  technique IDs so they surface in rule.mitre.id and register on the coverage map.

  Note: T1057 (Process Discovery via ps) is already covered by built-in Wazuh
  rule 92604, which carries the T1057 mitre tag - no custom rule needed for it.
  These two rules fill the gaps for T1033 and T1087.001.
-->
<group name="sparring,audit,">
  <!-- T1033: System Owner/User Discovery (w, who) -->
  <rule id="100600" level="5">
    <if_group>audit</if_group>
    <field name="audit.execve.a0" type="pcre2">^(w|who)$</field>
    <description>Sparring [T1033]: System owner/user discovery command executed.</description>
    <mitre>
      <id>T1033</id>
    </mitre>
    <group>sparring_discovery,</group>
  </rule>

  <!-- T1087.001: Local Account Discovery (getent passwd/shadow/group) -->
  <rule id="100601" level="5">
    <if_group>audit</if_group>
    <field name="audit.execve.a0" type="pcre2">getent</field>
    <field name="audit.execve.a1" type="pcre2">^(passwd|shadow|group)$</field>
    <description>Sparring [T1087.001]: Local account discovery via getent.</description>
    <mitre>
      <id>T1087.001</id>
    </mitre>
    <group>sparring_discovery,</group>
  </rule>
</group>
